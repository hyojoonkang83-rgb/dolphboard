# Server
NODE_ENV=production
PORT=3000
YJS_PORT=1234
CLIENT_URL=https://yourdomain.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dolphboard

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=7d

# Storage
STORAGE_TYPE=local   # or: s3
UPLOAD_DIR=./uploads

# S3 (required when STORAGE_TYPE=s3)
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=my-dolphboard-uploads
# S3_ENDPOINT=              # MinIO endpoint (optional)
# S3_CDN_URL=               # CloudFront URL (optional)
